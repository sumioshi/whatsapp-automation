# Copie para .env e ajuste se quiser. Todos têm default — funciona sem .env.

# Pasta onde fica a sessão do WhatsApp (credenciais). Não versionar.
AUTH_DIR=auth

# Pasta raiz onde o conteúdo é gravado, organizado por grupo.
DATA_DIR=data

# Arquivo de configuração de grupos (gerado automaticamente na 1ª conexão).
GROUPS_CONFIG=groups.config.json

# Nível de log da aplicação: trace | debug | info | warn | error
LOG_LEVEL=info

# Nível de log interno do Baileys (costuma ser barulhento): warn é um bom default.
BAILEYS_LOG_LEVEL=warn

# === Sync nuvem→Mac (opcional, só no Mac) ===
# Vazio = desligado (comportamento padrão). Com isto setado, `npm run dev` puxa o
# gap que a nuvem capturou (enquanto o Mac esteve off) antes de subir o coletor, e
# a mídia é baixada da nuvem sob demanda. URL do painel na nuvem (Tailscale no caso
# atual) + Basic Auth do painel (= PANEL_USER/PANEL_PASS setados na nuvem).
WAC_CLOUD_URL=
WAC_CLOUD_USER=
WAC_CLOUD_PASS=
# Escopo: 'local' (default) só os grupos que o Mac já acompanha; 'all' traz tudo
# (a nuvem tem centenas de DMs/grupos da history sync). Paralelismo: default 8.
WAC_SYNC_SCOPE=
WAC_SYNC_CONCURRENCY=

# Recado automático de expediente (scripts/expediente-scheduler.ts).
# Intervalo do tick em ms (default 300000 = 5min). O config fica em data/expediente.json.
# WAC_EXPEDIENTE_INTERVALO_MS=300000
