{
  "name": "whatsapp-group-collector",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "license": "Apache-2.0",
  "description": "Coletor 24/7 de conteúdo (áudio, vídeo, imagem, documento, texto) de grupos de WhatsApp, organizado por grupo.",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "npm run sync || true && concurrently -k -n collector,panel,transcriber,notifier -c cyan,green,magenta,yellow \"npm:dev:collector\" \"npm:dev:panel\" \"npm:dev:transcriber\" \"npm:dev:notifier\"",
    "dev:collector": "tsx watch src/index.ts",
    "dev:panel": "npm --prefix web run dev",
    "dev:transcriber": "\"$HOME/.local/share/uv/tools/mlx-whisper/bin/python\" transcriber/service.py",
    "dev:notifier": "node --import tsx scripts/notifier.ts",
    "start": "node --env-file-if-exists=.env dist/index.js",
    "start:cloud": "concurrently -k -n collector,panel -c cyan,green \"node dist/index.js\" \"npm --prefix web run start\"",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "check": "biome check src",
    "format": "biome check --write src",
    "sync": "node --env-file-if-exists=.env --import tsx scripts/sync-pull.ts",
    "expediente": "node --env-file-if-exists=.env --import tsx scripts/expediente-scheduler.ts",
    "test": "vitest run",
    "postinstall": "patch-package"
  },
  "dependencies": {
    "baileys": "^7.0.0-rc13",
    "link-preview-js": "^3.2.0",
    "pino": "^10.3.1",
    "qrcode-terminal": "^0.12.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@types/node": "^26.0.0",
    "@types/qrcode-terminal": "^0.12.2",
    "concurrently": "^10.0.3",
    "patch-package": "^8.0.1",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
